{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Authority Reference Packet",
  "type": "object",
  "required": [
    "schema_version",
    "authority_packet_id",
    "created_at",
    "intent",
    "domain",
    "authority_state",
    "references",
    "created_authority",
    "lineage"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "authority_packet_id": { "type": "string" },
    "created_at": { "type": "string" },
    "intent": { "type": "string" },
    "domain": { "type": "string" },
    "authority_state": {
      "enum": ["official", "local", "created", "blocked"]
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "authority_class", "url", "source_path", "scope"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "authority_class": {
            "enum": ["external", "local", "created"]
          },
          "url": { "type": ["string", "null"] },
          "source_path": { "type": ["string", "null"] },
          "scope": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "created_authority": {
      "type": "object",
      "required": ["required", "reason", "experiment_path"],
      "properties": {
        "required": { "type": "boolean" },
        "reason": { "type": "string" },
        "experiment_path": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "lineage": {
      "type": "object",
      "required": ["sequence_rank", "script_id", "evidence"],
      "properties": {
        "sequence_rank": { "const": "SEQ-D" },
        "script_id": { "type": "string" },
        "evidence": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
