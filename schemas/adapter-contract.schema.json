{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adapter Contract",
  "type": "object",
  "required": [
    "adapter_id",
    "framework",
    "runtime",
    "package_managers",
    "anchor_map",
    "target_path_rules",
    "input_contracts",
    "output_packets",
    "transform_contract",
    "placement_hooks",
    "style_hooks",
    "verification_commands",
    "repair_artifact_outputs"
  ],
  "properties": {
    "adapter_id": { "type": "string" },
    "framework": { "type": "string" },
    "runtime": { "enum": ["browser", "server", "fullstack", "unknown"] },
    "package_managers": { "type": "array", "items": { "type": "string" } },
    "anchor_map": { "type": "object", "additionalProperties": { "type": "string" } },
    "target_path_rules": { "type": "array", "items": { "type": "string" } },
    "input_contracts": { "type": "array", "items": { "type": "string" } },
    "output_packets": { "type": "array", "items": { "type": "string" } },
    "transform_contract": {
      "type": "object",
      "required": ["portable_format", "consumes", "emits"],
      "properties": {
        "portable_format": { "const": "json" },
        "consumes": { "type": "array", "items": { "type": "string" } },
        "emits": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "placement_hooks": { "type": "array", "items": { "type": "string" } },
    "style_hooks": { "type": "array", "items": { "type": "string" } },
    "verification_commands": { "type": "array", "items": { "type": "string" } },
    "repair_artifact_outputs": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
