{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Effect Comparison",
  "type": "object",
  "required": [
    "schema_version",
    "script_id",
    "expected",
    "observed",
    "effect_state",
    "mismatch",
    "next"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "script_id": { "type": "string" },
    "expected": {},
    "observed": {},
    "effect_state": {
      "enum": ["functional", "mismatched", "blocked", "superseded", "unverified"]
    },
    "mismatch": {
      "type": "object",
      "required": ["type", "detail", "repair_layer"],
      "properties": {
        "type": { "type": "string" },
        "detail": { "type": "string" },
        "repair_layer": { "type": "string" }
      },
      "additionalProperties": false
    },
    "next": {
      "enum": ["continue", "modification_loop_flagged", "blocked"]
    }
  },
  "additionalProperties": false
}
