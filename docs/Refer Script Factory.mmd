flowchart TD
  FS[Factory System] --> SF[Script Factory]
  FS --> CF[Context Factory]
  FS --> MF[Model Factory]
  FS --> AF[Artifact Factory]

  SF --> SC[Scriptionary]
  SF --> ST[Scriptonomy]
